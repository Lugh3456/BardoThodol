{
  "site_name": "Bardo Thodol",
  "language": "en",

  "pages": {
    "pattern": "section{n}.html",
    "count": 11,
    "label": "section",
    "check_title_h1": false
  },

  "content": {
    "source_text_element": "p",
    "source_text_id": "mainText",
    "explanation_section_class": "line-explanation",
    "explanation_card_class": "explanation-card",
    "card_line_selector": "p.line",
    "line_split_punctuation": ".?!;",
    "reference_file": "reference.py",
    "reference_variable": "TEXT"
  },

  "structure": {
    "required_sections": ["full-text", "line-explanation", "summary"],
    "required_elements": ["portal-bar", "site-footer", "skip-link", "read-btn"],
    "required_scripts": ["speechSynthesis"],
    "required_links": ["style.css", "fonts.googleapis.com", "index.html"],
    "html_lang": "en"
  }
}
